# ============================================================
#  各家 API Key 配置 (会被 ccx 加载)
#  安装脚本会把本文件复制为 ~/.config/claude-switch/keys.env 并设为 600 权限
#  只需填你要用的那家; 未用到的可留空。
# ============================================================

# 硅基流动 (glm / glmv / kimi / multi 使用)
# 获取: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_KEY="sk-在此粘贴你的硅基流动Key"

# 智谱官方 BigModel (zhipu 使用)
# 获取: https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_KEY="在此粘贴你的智谱Key"

# DeepSeek 官方 (deepseek 使用)
# 获取: https://platform.deepseek.com/api_keys
DEEPSEEK_KEY="sk-在此粘贴你的DeepSeekKey"
